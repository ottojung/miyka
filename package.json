    "@rollup/plugin-typescript": "^12.1.2",
    "@types/csv-parse": "^1.1.12",
    "@types/jest": "^29.5.14",
    "eslint": "^8.57.1",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
