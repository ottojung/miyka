{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitAny": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "dist/types",
        "rootDir": "src"
    },
    "include": ["src/**/*.js"]
}
